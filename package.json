{
  "name": "tailark",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Méschac Irung",
    "email": "meschacirung@gmail.com",
    "url": "https://x.com/MeschacIrung"
  },
  "packageManager": "pnpm@9.10.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @treonstudio/website dev",
    "build": "pnpm --filter @treonstudio/website build",
    "start": "pnpm --filter @treonstudio/website start",
    "preview": "pnpm --filter @treonstudio/website preview",
    "lint": "pnpm --filter @treonstudio/website lint",
    "check": "pnpm --filter @treonstudio/website check",
    "registry:build": "shadcn build",
    "gateway:dev": "pnpm --filter @treonstudio/gateway dev",
    "gateway:dev:node": "pnpm --filter @treonstudio/gateway dev:node",
    "gateway:build": "pnpm --filter @treonstudio/gateway build",
    "gateway:deploy": "pnpm --filter @treonstudio/gateway deploy"
  },
  "devDependencies": {
    "prettier": "3.5.1",
    "prettier-plugin-tailwindcss": "0.6.11",
    "typescript": "^5"
  },
  "dependencies": {
    "turbo": "^2.5.3"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "@types/react": "^19.1.3",
      "@types/react-dom": "^19.1.3"
    }
  }
}
