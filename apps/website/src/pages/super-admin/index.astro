---
import SuperAdminLayout from '@/layouts/SuperAdminLayout.astro'
import { query } from "@/lib/neon/client"
import { Card, CardHeader, CardTitle, CardContent } from '@treonstudio/bungas-core/ui/card'
import { Badge } from '@treonstudio/bungas-core/ui/badge'
import { Buildings2Linear, UsersGroupTwoRoundedLinear, FileTextLinear, CodeLinear, ClockCircleLinear, PulseLinear } from 'solar-icon-set';
import { ArrowRightUpLinear, GraphUpLinear } from 'solar-icon-set';;

const session = Astro.locals.session
if (!session) {
  return Astro.redirect('/login')
}

// Query real-time server-side aggregate metrics in parallel
const [companiesResult, membershipsResult, handoffsResult, logsResult] = await Promise.all([
  query("SELECT COUNT(*) AS count FROM public.companies"),
  query("SELECT COUNT(*) AS count FROM public.company_memberships"),
  query("SELECT COUNT(*) AS count FROM public.handoff_artefacts"),
  query("SELECT COUNT(*) AS count FROM public.app_logs"),
])

const companiesCount = Number(companiesResult.rows[0]?.count ?? 0)
const membershipsCount = Number(membershipsResult.rows[0]?.count ?? 0)
const handoffsCount = Number(handoffsResult.rows[0]?.count ?? 0)
const logsCount = Number(logsResult.rows[0]?.count ?? 0)

// Fetch 5 latest handoffs
const { rows: recentHandoffs } = await query(
  "SELECT * FROM public.handoff_artefacts ORDER BY created_at DESC LIMIT 5"
)
---

<SuperAdminLayout title="Overview Dashboard - Super Admin Console">
  <div class="p-6 md:p-8 space-y-6 max-w-6xl mx-auto">
    <!-- Greet Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight">Overview Dashboard</h1>
        <p class="text-sm text-text-secondary">Selamat datang kembali di pusat kontrol operasional TenangAI.</p>
      </div>
      <div class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-green-500/10 border border-green-500/20 text-xs text-green-500 font-semibold">
        <PulseLinear className="h-3 w-3 animate-pulse" />
        Sistem Normal
      </div>
    </div>

    <!-- Metrics Swatches Grid -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <Card className="bg-surface-primary border-border-primary text-text-primary">
        <CardContent className="p-6 flex items-center justify-between">
          <div class="space-y-1">
            <p class="text-xs font-semibold text-text-secondary uppercase tracking-wider">Total Tenant Aktif</p>
            <h3 class="text-3xl font-bold">{companiesCount ?? 0}</h3>
            <p class="text-[10px] text-green-500 flex items-center gap-1 font-medium mt-1">
              <GraphUpLinear className="h-3 w-3" />
              B2B Organisasi
            </p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-brand-primary/10 text-brand-primary flex items-center justify-center shrink-0">
            <Buildings2Linear className="h-6 w-6" />
          </div>
        </CardContent>
      </Card>

      <Card className="bg-surface-primary border-border-primary text-text-primary">
        <CardContent className="p-6 flex items-center justify-between">
          <div class="space-y-1">
            <p class="text-xs font-semibold text-text-secondary uppercase tracking-wider">Total Kursi Member</p>
            <h3 class="text-3xl font-bold">{membershipsCount ?? 0}</h3>
            <p class="text-[10px] text-text-secondary flex items-center gap-1 font-medium mt-1">
              <UsersGroupTwoRoundedLinear className="h-3 w-3" />
              Kursi terisi aktif
            </p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-blue-500/10 text-blue-500 flex items-center justify-center shrink-0">
            <UsersGroupTwoRoundedLinear className="h-6 w-6" />
          </div>
        </CardContent>
      </Card>

      <Card className="bg-surface-primary border-border-primary text-text-primary">
        <CardContent className="p-6 flex items-center justify-between">
          <div class="space-y-1">
            <p class="text-xs font-semibold text-text-secondary uppercase tracking-wider">Sales Handoffs</p>
            <h3 class="text-3xl font-bold">{handoffsCount ?? 0}</h3>
            <p class="text-[10px] text-amber-500 flex items-center gap-1 font-medium mt-1">
              <ClockCircleLinear className="h-3 w-3" />
              Menunggu Provisioning
            </p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-amber-500/10 text-amber-500 flex items-center justify-center shrink-0">
            <FileTextLinear className="h-6 w-6" />
          </div>
        </CardContent>
      </Card>

      <Card className="bg-surface-primary border-border-primary text-text-primary">
        <CardContent className="p-6 flex items-center justify-between">
          <div class="space-y-1">
            <p class="text-xs font-semibold text-text-secondary uppercase tracking-wider">Application Logs</p>
            <h3 class="text-3xl font-bold">{logsCount ?? 0}</h3>
            <p class="text-[10px] text-text-secondary flex items-center gap-1 font-medium mt-1">
              <CodeLinear className="h-3 w-3" />
              Struktur Log system
            </p>
          </div>
          <div class="h-12 w-12 rounded-lg bg-purple-500/10 text-purple-500 flex items-center justify-center shrink-0">
            <CodeLinear className="h-6 w-6" />
          </div>
        </CardContent>
      </Card>
    </div>

    <!-- Split content: Recent Handoffs & Action Guides -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Recent Sales Handoffs -->
      <div class="lg:col-span-2 space-y-4">
        <h2 class="text-xl font-bold">Sales Handoffs Terbaru</h2>
        <Card className="bg-surface-primary border-border-primary text-text-primary">
          <CardContent className="p-0">
            {recentHandoffs && recentHandoffs.length > 0 ? (
              <div class="divide-y divide-border-primary">
                {recentHandoffs.map((h: any) => (
                  <div class="flex items-center justify-between p-4 hover:bg-surface-secondary/30 transition-colors">
                    <div class="space-y-1">
                      <div class="font-bold flex items-center gap-2">
                        {h.company_name}
                        <Badge className="bg-blue-500/10 text-blue-500 border-none capitalize text-[10px]">{h.billing_model.replace('_', ' ')}</Badge>
                      </div>
                      <p class="text-xs text-text-secondary">Admin: {h.company_admin_email} • Ukuran: {h.company_size} karyawan</p>
                    </div>
                    <a
                      href="/super-admin/tenants"
                      class="flex items-center gap-1 px-3 py-1.5 text-xs text-brand-primary font-bold hover:bg-brand-primary/10 rounded-lg transition-colors border border-transparent"
                    >
                      Provision
                      <ArrowRightUpLinear className="h-3 w-3" />
                    </a>
                  </div>
                ))}
              </div>
            ) : (
              <div class="text-center py-12 text-text-secondary">Belum ada dokumen Sales Handoff.</div>
            )}
          </CardContent>
        </Card>
      </div>

      <!-- Action Guides -->
      <div class="space-y-4">
        <h2 class="text-xl font-bold">Panduan Ops Cepat</h2>
        <div class="space-y-4">
          <Card className="bg-surface-primary border-border-primary text-text-primary">
            <CardHeader className="pb-2">
              <CardTitle className="text-sm font-bold">1. Tambah Sales Handoff</CardTitle>
            </CardHeader>
            <CardContent className="text-xs text-text-secondary space-y-2">
              <p>Menerima detail kontrak dari sales marketing? Log handoff tersebut ke menu **Sales Handoffs**.</p>
              <a href="/super-admin/handoffs" class="text-brand-primary font-bold flex items-center gap-1">
                Buka Sales Handoffs &rarr;
              </a>
            </CardContent>
          </Card>

          <Card className="bg-surface-primary border-border-primary text-text-primary">
            <CardHeader className="pb-2">
              <CardTitle className="text-sm font-bold">2. Provisioning Tenant B2B</CardTitle>
            </CardHeader>
            <CardContent className="text-xs text-text-secondary space-y-2">
              <p>Lakukan deployment database dan isolasi container tenant baru dari dokumen handoff di tab **Tenants Provisioning**.</p>
              <a href="/super-admin/tenants" class="text-brand-primary font-bold flex items-center gap-1">
                Buka Tenants Provisioning &rarr;
              </a>
            </CardContent>
          </Card>
        </div>
      </div>
    </div>
  </div>
</SuperAdminLayout>
