---
import SuperAdminLayout from '@/layouts/SuperAdminLayout.astro'
import { HandoffManagement } from '@/../blocks/super-admin/HandoffManagement'
---

<SuperAdminLayout title="Sales Handoffs - Super Admin Console">
  <div class="p-6 md:p-8 space-y-6 max-w-6xl mx-auto">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight">Sales Handoffs</h1>
      <p class="text-sm text-text-secondary">Kelola, tinjau, dan daftarkan kontrak kerjasama B2B hasil sales handoff.</p>
    </div>

    <HandoffManagement client:load />
  </div>
</SuperAdminLayout>
