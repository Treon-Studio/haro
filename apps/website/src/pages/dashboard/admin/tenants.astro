---
import BaseLayout from '@/layouts/BaseLayout.astro'
import TenantList from '@/../blocks/dashboard/admin/tenant-list'

export const prerender = false

// Auth gate — redirect if not admin
const token = import.meta.env.DASHBOARD_TOKEN
if (token) {
  const cookieToken = Astro.request.headers.get('cookie')
    ?.split(';').map(c => c.trim()).find(c => c.startsWith('dashboard_token='))?.split('=')[1]
  const headerToken = Astro.request.headers.get('x-dashboard-token')
  if (cookieToken !== token && headerToken !== token) {
    return Astro.redirect('/login')
  }
}
---

<BaseLayout title="Admin — Tenants" description="Tenant Management">
  <div class="flex h-screen overflow-hidden bg-background">
    <aside class="w-56 shrink-0 border-r border-border bg-card p-4">
      <h1 class="text-lg font-bold mb-6">Admin</h1>
      <nav class="flex flex-col gap-1">
        <a href="/dashboard/admin/tenants" class="px-3 py-2 rounded-md text-sm bg-surface-active font-medium">Tenants</a>
        <a href="/dashboard" class="px-3 py-2 rounded-md text-sm text-text-secondary hover:bg-surface-hover">Memory Explorer</a>
      </nav>
    </aside>
    <main class="flex-1 overflow-y-auto p-6">
      <h2 class="text-2xl font-bold mb-1">Tenants</h2>
      <p class="text-sm text-text-secondary mb-4">Manage organizations and their resource access.</p>
      <TenantList client:load />
    </main>
  </div>
</BaseLayout>
