[Unit]
Description=Fabric Monitor — health check + Discord alerts
After=network-online.target

[Service]
Type=simple
User=root
Environment=DISCORD_WEBHOOK_URL=
ExecStart=/opt/memory-fabric-mcp-venv/bin/python /root/go-workspace/haro/apps/memory-fabric/scripts/monitor.py --daemon
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
